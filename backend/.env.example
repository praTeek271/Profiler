# ============================================================
# Profiler Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored and never committed.
# ============================================================

# -----------------------------------------------
# AWS
# -----------------------------------------------
AWS_REGION=us-east-1

# Optional: only needed if NOT using `aws configure` or IAM role
# Leave blank when running on a machine with aws configure already set up.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------
# DynamoDB Table Names
# These must match exactly what you create in AWS.
# -----------------------------------------------
PATIENT_TABLE=profiler-patientDB
RECORDS_TABLE=profiler-medicalrecordDB

# -----------------------------------------------
# Redis Cloud
# Get this from your Redis Cloud database dashboard:
#   Database → Connect → ioredis / Node.js
# Format: rediss://:<password>@<host>:<port>
# -----------------------------------------------
REDIS_URL=rediss://:<password>@<host>:<port>
